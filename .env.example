# ── SurrealDB ────────────────────────────────────────────────────────────────
SURREAL_USER=root
SURREAL_PASS=changeme
SURREAL_PORT=8000
SURREAL_NS=domovoy
SURREAL_DB=domovoy

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASS=changeme
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=domovoy

# ── Web ──────────────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXTAUTH_SECRET=changeme
NEXTAUTH_URL=http://localhost:3000

# ── Ollama (GPU-сервер) ──────────────────────────────────────────────────────
# Если Ollama на отдельном сервере — указать его адрес
# Если локально — http://host.docker.internal:11434
OLLAMA_ENDPOINT=http://gpu-server.home:11434
OLLAMA_LLM_MODEL=qwen2.5:32b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=bge-m3

# ── Telegram (опционально) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Surrealist GUI ───────────────────────────────────────────────────────────
SURREALIST_PORT=8080
SURREALIST_VERSION=surrealist-v3.8.5

# ── Workers ──────────────────────────────────────────────────────────────────
WORKER_HEARTBEAT_INTERVAL=30    # секунд между heartbeat-апдейтами
WORKER_LOCK_TTL=300             # секунд до авто-освобождения зависшей задачи
WORKER_POLL_INTERVAL=60         # секунд между тиками планировщика
