CREATE thing:`note_vasich_tools` SET kind = 'заметка', name = 'Одолженный инструмент у Васича', body = 'Одолжил шуруповёрт, болгарку и компрессор. Просил вернуть до конца мая. Звонить на мобильный +7-916-222-33-44. Живёт в 47-й квартире.', created_at = time::now();
RELATE thing:`note_vasich_tools`->about->thing:`neighbor_vasich`;
CREATE thing:`note_grandma_garden_plan` SET kind = 'заметка', name = 'Что нужно для огорода бабушки', body = 'Бабушка хочет: грядки под томаты (3 шт), грядка под огурцы, зелень. Нужно привезти: торф 2 мешка, колышки, рассаду томатов от Мамы. Папа обещал сделать до июня. Бабушка напомнила уже 3 раза.', created_at = time::now();
RELATE thing:`note_grandma_garden_plan`->about->thing:`task_grandma_garden`;
CREATE thing:`note_boat_season_2026` SET kind = 'заметка', name = 'Заметки по катеру на сезон 2026', body = 'Игорь (моторист) сказал: мотор в порядке, но карбюратор надо почистить. Стоянка оплачена до сентября. Нужно купить новые весла (старые сломали в 2025). Планируем поездку на остров Песчаный в июле — взять мангал и ночевать.', created_at = time::now();
RELATE thing:`note_boat_season_2026`->about->thing:`boat_viking`;
CREATE thing:`note_son_karate` SET kind = 'заметка', name = 'Карате — прогресс', body = 'Тренер Максим Александрович говорит прогресс хороший. Следующий пояс (синий) — экзамен в сентябре. Нужна новая кимоно (вырос из старой). Размер 140 сейчас.', created_at = time::now();
RELATE thing:`note_son_karate`->about->thing:`user_son`;
CREATE thing:`note_avito_tips` SET kind = 'заметка', name = 'Советы по продажам на Авито', body = 'Объявления лучше поднимать в четверг вечером и воскресенье утром — больше просмотров. Велосипед: торговаться можно до 2200, ниже не отдавать. Компрессор: только самовывоз, тяжёлый (35кг). Звонить не раньше 10 утра.', created_at = time::now();
RELATE thing:`note_avito_tips`->about->thing:`user_papa`;
CREATE thing:`note_diag_allergy` SET kind = 'заметка', name = 'Аллергия у Сына — что делать', body = 'Аллерголог Носков сказал: сдать кровь на панель аллергенов. Пока принимать Лоратадин 1 таб/день в период обострения. Следующий приём через 3 месяца. Запись через Госуслуги.', created_at = time::now();
RELATE thing:`note_diag_allergy`->about->thing:`diag_allerg`;

